AJS_HOST=127.0.0.1
AJS_PORT=3000
AJS_DB_PATH=./scheduler.db
AJS_LOG_LEVEL=info
AJS_DEFAULT_LANGUAGE=en
AJS_MAX_CONCURRENT_JOBS=10
AJS_HTTP_TIMEOUT_SECONDS=60
AJS_JOB_TICK_INTERVAL_MS=1000
AJS_ENABLE_JS_TRANSFORM=true
AJS_RETENTION_DAYS=30
AJS_LOG_DIR=./logs
# true = run jobs whose next_run_at is in the past right after startup; false = reschedule from now without running
AJS_RUN_OVERDUE_ON_STARTUP=true
# true = set enabled=0 for all jobs on startup (turn on jobs manually in the UI)
AJS_DISABLE_ALL_JOBS_ON_STARTUP=false
